OPENAI_API_KEY=

# Нужны для автозаполнения названия/исполнителя/альбома/обложки (Spotify Web API).
# Получить: https://developer.spotify.com/dashboard -> Create app
# Redirect URI при создании укажите любой (например http://localhost:3000) — он не используется,
# т.к. используется Client Credentials Flow (без входа пользователя).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Необязательно: запасной источник метаданных/текста песни на случай, если
# Spotify недоступен (например, требует Premium-подписку у владельца
# приложения) или ничего не нашёл. Поиск и метаданные Яндекс.Музыки в
# основном доступны и без токена — оставьте пустым, если не нужно.
# Получить токен: https://ym.marshal.dev/token/#implicit-oauth
YANDEX_MUSIC_TOKEN=
