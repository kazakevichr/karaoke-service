OPENAI_API_KEY=

# Нужны для автозаполнения названия/исполнителя/альбома/обложки (Spotify Web API).
# Получить: https://developer.spotify.com/dashboard -> Create app
# Redirect URI при создании укажите любой (например http://localhost:3000) — он не используется,
# т.к. используется Client Credentials Flow (без входа пользователя).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Яндекс.Музыка — запасной источник метаданных/текста песни (на случай, если
# Spotify недоступен или ничего не нашёл), и, что важнее, ОСНОВНОЙ источник
# скачивания самого аудио для «Массовой загрузки» и «Заменить аудио»: YouTube
# в последнее время часто блокирует скачивание с серверных IP, а Яндекс —
# пока нет. Поиск/метаданные доступны и без токена, но для надёжного
# скачивания самого аудиофайла токен настоятельно рекомендуется — без него
# скачивание может не работать для части треков.
# Получить токен: https://ym.marshal.dev/token/#implicit-oauth
YANDEX_MUSIC_TOKEN=

# Путь к файлу базы SQLite с общим банком треков и раундами (метаданные —
# название/исполнитель/текст/тайминги/раунды). ВАЖНО: в проде это должен быть
# путь на персистентном томе (Storages в Coolify), иначе банк будет
# обнуляться при каждом передеплое. Локально можно не задавать — по
# умолчанию создастся ./data/karaoke.db рядом с проектом.
DB_PATH=

# S3-совместимое хранилище для самих аудиофайлов и обложек (например,
# S3-хранилище в Timeweb Cloud). Без этих переменных сохранение/загрузка
# треков в общий банк работать не будет — остальной функционал (поиск,
# распознавание и т.д.) не пострадает.
# S3_ENDPOINT — адрес API хранилища (например https://s3.timeweb.cloud)
# S3_REGION — регион (для Timeweb обычно ru-1)
# S3_BUCKET — имя бакета
# S3_ACCESS_KEY / S3_SECRET_KEY — ключи доступа (создаются в разделе S3 в Timeweb)
# S3_PUBLIC_BASE_URL — базовый URL, по которому объекты бакета доступны публично
#   (если не задан — соберётся из S3_ENDPOINT + S3_BUCKET, но лучше указать явно,
#   если у бакета свой домен/CDN)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
